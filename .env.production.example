# Production Environment Variables
# Copy this file to .env and fill in your actual production values

# Security Keys - MUST BE DIFFERENT FROM DEVELOPMENT!
SALT_KEY=
TOKEN_KEY=

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@uniza.sk

# Frontend URL - Your actual production domain
FRONTEND_URL=https://yourdomain.com

# MongoDB Credentials - Use strong passwords!
MONGO_USER=mongoUser
MONGO_PASSWORD=
